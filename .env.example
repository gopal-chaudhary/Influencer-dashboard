# xAI / Grok configuration
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
# Set XAI_MODEL to a valid model available on your xAI account.
# You can also provide a comma-separated fallback list.
XAI_MODEL=grok-4-latest
XAI_MODEL_CANDIDATES=grok-4-latest,grok-3-latest,grok-2-latest
XAI_TEMPERATURE=0.2
XAI_MAX_TOKENS=600
XAI_TIMEOUT_SECONDS=60
XAI_MAX_RETRIES=3
XAI_RETRY_INITIAL_DELAY_SECONDS=1
XAI_RETRY_MAX_DELAY_SECONDS=8

# Application logging
LOG_LEVEL=INFO
